# 特定商取引法・お問い合わせ（Square審査用）
NEXT_PUBLIC_OPERATOR_NAME=
NEXT_PUBLIC_CONTACT_EMAIL=

# 本番デプロイ時のサイトURL（OGP・sitemap用）
# Vercel では自動で VERCEL_URL が設定されるため、多くの場合不要
NEXT_PUBLIC_SITE_URL=https://qp-lime.vercel.app

# 収益化（広告・Premium）
# Google AdSense（AdSenseで広告ユニット作成後に取得）
NEXT_PUBLIC_ADSENSE_CLIENT_ID=
NEXT_PUBLIC_ADSENSE_SLOT_ID=
# Premium購入URL（外部決済URL、Square未使用時用）
NEXT_PUBLIC_PREMIUM_PURCHASE_URL=

# Square（Developer Consoleでアプリ作成後、CredentialsとLocationsから取得）
# 本番用: Production の Credentials と Locations を使用
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
NEXT_PUBLIC_SQUARE_LOCATION_ID=

# PayPay Open Payment API（PayPay for Developersで加盟店登録後、API Key/Secretを取得）
# 本番: PAYPAY_PRODUCTION=true
# 決済トランザクション通知 Webhook: https://qp-lime.vercel.app/api/webhooks/paypay
PAYPAY_API_KEY=
PAYPAY_API_SECRET=
PAYPAY_PRODUCTION=true

# ライセンスキー（Upstash Redis / Vercel KV）
# Vercel Dashboard の Storage または Upstash で作成後、環境変数に設定
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Square Webhook（payment.updated でライセンスキー発行）
# Developer Console の Webhooks で通知URLを登録後、署名キーを設定
# 本番通知URL: https://qp-lime.vercel.app/api/webhooks/square
SQUARE_WEBHOOK_SIGNATURE_KEY=
SQUARE_WEBHOOK_NOTIFICATION_URL=https://qp-lime.vercel.app/api/webhooks/square

# Resend（Square購入者へライセンスキーをメール送信）
# https://resend.com でAPIキー取得、ドメイン認証後に from アドレスを設定
RESEND_API_KEY=
RESEND_FROM_EMAIL=
# テスト用（任意）: /api/test-email の ?secret= と一致すると呼び出し可能
# TEST_EMAIL_SECRET=

# OpenAI（フリマ商品カメラ認識 / GPT-4o Vision）
# https://platform.openai.com/api-keys でAPIキーを取得
OPENAI_API_KEY=
